filters:
  and:
    - file.folder == "Papers/arXiv"
properties:
  note.short_title:
    displayName: Short Title
  note.title:
    displayName: Title
  note.paper_status:
    displayName: Paper Status
  note.category:
    displayName: Category
  note.publish_date:
    displayName: Publish Date
  note.abstract:
    displayName: Abstract
views:
  - type: table
    name: 全部
    order:
      - short_title
      - file.name
      - title
      - paper_status
      - category
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
  - type: table
    name: To Read
    filters:
      and:
        - note.paper_status == "To Read"
    order:
      - short_title
      - file.name
      - title
      - category
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
  - type: table
    name: Reading
    filters:
      and:
        - note.paper_status == "Reading"
    order:
      - short_title
      - file.name
      - title
      - category
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
  - type: table
    name: Done
    filters:
      and:
        - note.paper_status == "Done"
    order:
      - short_title
      - file.name
      - title
      - category
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
  - type: table
    name: End2End
    filters:
      and:
        - note.category.contains("End2End")
    order:
      - short_title
      - file.name
      - title
      - paper_status
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
  - type: table
    name: BEV
    filters:
      and:
        - note.category.contains("BEV")
    order:
      - short_title
      - file.name
      - title
      - paper_status
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
  - type: table
    name: Occupancy
    filters:
      and:
        - note.category.contains("Occupancy")
    order:
      - short_title
      - file.name
      - title
      - paper_status
      - publish_date
      - abstract
    sort:
      - property: publish_date
        direction: DESC
