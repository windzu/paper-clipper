{
  "manifest_version": 3,
  "name": "Paper Clipper",
  "version": "0.1.0",
  "description": "Clip arXiv papers into Obsidian as structured paper notes.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://arxiv.org/*",
    "https://ar5iv.labs.arxiv.org/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Paper Clipper"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html"
}
